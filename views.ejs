<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📡 OSINT API Hub - Live Endpoints</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            background: radial-gradient(circle at 20% 50%, #0a0f1e, #05080f);
            font-family: 'Inter', sans-serif;
            color: #e0e0e0;
            min-height: 100vh;
        }
        
        /* Liquid Glass Navbar */
        .navbar {
            background: rgba(10, 20, 30, 0.6);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0, 255, 200, 0.3);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .logo {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #00ffcc, #0099ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .nav-links a {
            color: #ccc;
            text-decoration: none;
            margin-left: 2rem;
            transition: 0.3s;
        }
        
        .nav-links a:hover { color: #00ffcc; text-shadow: 0 0 10px #00ffcc; }
        
        /* Hero Section */
        .hero {
            text-align: center;
            padding: 3rem 2rem;
            background: linear-gradient(135deg, rgba(0,255,200,0.05), rgba(0,100,255,0.05));
        }
        
        .hero h1 {
            font-size: 3rem;
            background: linear-gradient(135deg, #fff, #00ffcc);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .stats-grid {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }
        
        .stat-card {
            background: rgba(0, 255, 200, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 255, 200, 0.2);
            border-radius: 20px;
            padding: 1rem 2rem;
            text-align: center;
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #00ffcc;
        }
        
        /* Endpoint Grid */
        .container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 2rem;
        }
        
        .endpoint-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        
        .endpoint-card {
            background: rgba(15, 25, 35, 0.7);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(0, 255, 200, 0.2);
            border-radius: 24px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .endpoint-card:hover {
            transform: translateY(-5px);
            border-color: #00ffcc;
            box-shadow: 0 10px 40px rgba(0, 255, 200, 0.2);
        }
        
        .endpoint-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }
        
        .endpoint-name {
            font-size: 1.3rem;
            font-weight: 700;
        }
        
        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        
        .status-up { background: #00ff8844; color: #00ff88; border: 1px solid #00ff88; }
        .status-down { background: #ff444444; color: #ff4444; border: 1px solid #ff4444; }
        
        .endpoint-url {
            background: #00000055;
            padding: 0.5rem;
            border-radius: 12px;
            font-family: monospace;
            font-size: 0.8rem;
            margin: 0.75rem 0;
            word-break: break-all;
        }
        
        .params {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin: 0.75rem 0;
        }
        
        .param {
            background: #1a2a3a;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-family: monospace;
        }
        
        .example {
            background: #0a1a2a;
            padding: 0.75rem;
            border-radius: 12px;
            font-size: 0.7rem;
            font-family: monospace;
            margin-top: 0.75rem;
            overflow-x: auto;
        }
        
        .copy-btn {
            background: rgba(0, 255, 200, 0.2);
            border: 1px solid #00ffcc;
            padding: 0.5rem 1rem;
            border-radius: 30px;
            color: #00ffcc;
            cursor: pointer;
            margin-top: 0.75rem;
            width: 100%;
            transition: 0.3s;
        }
        
        .copy-btn:hover {
            background: #00ffcc;
            color: #000;
            box-shadow: 0 0 15px #00ffcc;
        }
        
        .footer {
            text-align: center;
            padding: 2rem;
            border-top: 1px solid rgba(0,255,200,0.2);
            margin-top: 3rem;
        }
        
        @media (max-width: 768px) {
            .endpoint-grid { grid-template-columns: 1fr; }
            .navbar { flex-direction: column; gap: 1rem; }
            .nav-links a { margin: 0 1rem; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">🔐 OSINT API HUB</div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/endpoints">📡 Endpoints</a>
            <a href="/docs">📚 Docs</a>
            <a href="/login">🔑 Admin</a>
        </div>
    </nav>
    
    <div class="hero">
        <h1>📡 Live API Endpoints</h1>
        <p>All available OSINT APIs — test them live, copy examples, integrate instantly</p>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= apis.length %></div>
                <div>Available APIs</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">24/7</div>
                <div>Uptime</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">🔓</div>
                <div>No Restrictions</div>
            </div>
        </div>
    </div>
    
    <div class="container">
        <div class="endpoint-grid">
            <% apis.forEach(api => { %>
            <div class="endpoint-card" onclick="selectEndpoint('<%= api.name %>')">
                <div class="endpoint-header">
                    <span class="endpoint-name"><%= api.display_name %></span>
                    <span class="status-badge <%= statusMap[api.name] === false ? 'status-down' : 'status-up' %>">
                        <%= statusMap[api.name] === false ? '⚠️ Down' : '🟢 Live' %>
                    </span>
                </div>
                <div class="endpoint-url">
                    GET <span style="color:#00ffcc"><%= baseUrl %><%= api.endpoint %></span>
                </div>
                <div class="params">
                    <% (api.required_params || '').split(',').forEach(p => { %>
                        <span class="param"><%= p.trim() %></span>
                    <% }) %>
                </div>
                <div class="example">
                    📋 Example:<br>
                    <code><%= baseUrl %><%= api.endpoint %>?key=YOUR_API_KEY&<%= Object.entries(JSON.parse(api.example_params || '{}')).map(([k,v]) => `${k}=${v}`).join('&') %></code>
                </div>
                <button class="copy-btn" onclick="event.stopPropagation(); copyToClipboard('<%= baseUrl %><%= api.endpoint %>?key=YOUR_API_KEY&<%= Object.entries(JSON.parse(api.example_params || '{}')).map(([k,v]) => `${k}=${v}`).join('&') %>')">
                    📋 Copy Example URL
                </button>
            </div>
            <% }); %>
        </div>
    </div>
    
    <div class="footer">
        <p>🔐 Need an API key? Contact <strong>@BMW_AURA4</strong> or <strong>@BMW_AURA1</strong></p>
        <p>📢 Join our channel: <a href="https://t.me/OSINTERA_1" style="color:#00ffcc">https://t.me/OSINTERA_1</a></p>
        <p>© OSINT API Hub | All endpoints return owner info automatically</p>
    </div>
    
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text);
            alert('✅ URL copied to clipboard!');
        }
        
        function selectEndpoint(name) {
            console.log('Selected:', name);
        }
    </script>
</body>
</html>