<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Head Admin Dashboard - OSINT API Hub</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #0a0e27; color: #fff; }
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px; border-radius: 10px; margin-bottom: 30px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: rgba(255,255,255,0.1); padding: 20px; border-radius: 10px; text-align: center; }
        .stat-number { font-size: 2.5em; font-weight: bold; color: #667eea; }
        .card { background: #1a1f3a; border-radius: 10px; padding: 20px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #2a2f4a; }
        th { background: #667eea; color: #fff; }
        .btn { padding: 8px 16px; border: none; border-radius: 5px; cursor: pointer; font-size: 14px; }
        .btn-danger { background: #e74c3c; color: white; }
        .btn-success { background: #2ecc71; color: white; }
        .btn-primary { background: #3498db; color: white; }
        input, select { padding: 8px; border-radius: 5px; border: 1px solid #2a2f4a; background: #0a0e27; color: #fff; margin: 5px; }
        .nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .logout { background: #e74c3c; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; }
        .badge { padding: 3px 8px; border-radius: 5px; font-size: 12px; }
        .badge-success { background: #2ecc71; }
        .badge-danger { background: #e74c3c; }
        .badge-warning { background: #f39c12; }
    </style>
</head>
<body>
    <div class="container">
        <div class="nav">
            <h1>👑 Head Admin Dashboard</h1>
            <a href="/logout" class="logout">🚪 Logout</a>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= admins.length %></div>
                <div>Total Admins</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= keys.length %></div>
                <div>Total API Keys</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= totalHits %></div>
                <div>Total API Calls</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= todayStats.total_calls_today || 0 %></div>
                <div>Today's Calls</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= monthStats.total_calls_month || 0 %></div>
                <div>This Month</div>
            </div>
        </div>
        
        <div class="card">
            <h2>👥 Admin Management</h2>
            <form id="createAdminForm">
                <input type="text" id="adminUsername" placeholder="Username" required>
                <input type="password" id="adminPassword" placeholder="Password" required>
                <select id="adminRole">
                    <option value="admin">Admin</option>
                </select>
                <button type="submit" class="btn btn-success">Create Admin</button>
            </form>
            <div id="adminMessage"></div>
            
            <h3 style="margin-top: 20px;">Existing Admins</h3>
            <table>
                <thead>
                    <tr><th>Username</th><th>Role</th><th>Created By</th><th>Created At</th><th>Action</th></tr>
                </thead>
                <tbody>
                    <% admins.forEach(admin => { %>
                    <tr>
                        <td><%= admin.username %></td>
                        <td><span class="badge badge-warning"><%= admin.role %></span></td>
                        <td><%= admin.created_by || 'system' %></td>
                        <td><%= new Date(admin.created_at).toLocaleString() %></td>
                        <td><button onclick="removeAdmin(<%= admin.id %>)" class="btn btn-danger">Remove</button></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <div class="card">
            <h2>📊 API Keys & Call Statistics</h2>
            <table>
                <thead>
                    <tr><th>API Key</th><th>Name</th><th>Total Hits</th><th>Today</th><th>Yesterday</th><th>This Month</th><th>Status</th><th>Expiry</th></tr>
                </thead>
                <tbody>
                    <% keys.forEach(key => { %>
                    <tr>
                        <td><code><%= key.key %></code></td>
                        <td><%= key.name %></td>
                        <td><%= key.hits || 0 %></td>
                        <td><span class="badge badge-success"><%= key.today_calls || 0 %></span></td>
                        <td><%= key.yesterday_calls || 0 %></td>
                        <td><%= key.monthly_calls || 0 %></td>
                        <td><span class="badge <%= key.status === 'active' ? 'badge-success' : 'badge-danger' %>"><%= key.status %></span></td>
                        <td><%= key.expires_at ? new Date(key.expires_at).toLocaleDateString() : 'Never' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    
    <script>
        document.getElementById('createAdminForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const username = document.getElementById('adminUsername').value;
            const password = document.getElementById('adminPassword').value;
            const role = document.getElementById('adminRole').value;
            
            const response = await fetch('/head-admin/create-admin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password, role })
            });
            const data = await response.json();
            
            if (data.success) {
                document.getElementById('adminMessage').innerHTML = '<p style="color:green;">✅ ' + data.message + '</p>';
                setTimeout(() => location.reload(), 1000);
            } else {
                document.getElementById('adminMessage').innerHTML = '<p style="color:red;">❌ ' + data.error + '</p>';
            }
        });
        
        async function removeAdmin(id) {
            if (confirm('Are you sure you want to remove this admin?')) {
                const response = await fetch('/head-admin/remove-admin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ admin_id: id })
                });
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + data.error);
                }
            }
        }
    </script>
</body>
</html>
