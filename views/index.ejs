<!DOCTYPE html>
<html>
<head>
    <title>OSINT API Hub</title>
    <style>
        body {
            background: radial-gradient(circle at center, #0a0f2a, #000);
            font-family: 'Arial', sans-serif;
            text-align: center;
            color: #0ff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .glass {
            background: rgba(0,255,255,0.05);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 3rem;
            border: 1px solid rgba(0,255,255,0.3);
        }
        h1 { font-size: 3rem; text-shadow: 0 0 20px #0ff; }
        .btn {
            background: rgba(0,255,255,0.2);
            border: 1px solid #0ff;
            padding: 1rem 2rem;
            border-radius: 50px;
            color: #0ff;
            text-decoration: none;
            display: inline-block;
            margin: 1rem;
            transition: 0.3s;
        }
        .btn:hover { background: #0ff; color: #000; box-shadow: 0 0 30px #0ff; }
    </style>
</head>
<body>
    <div class="glass">
        <h1>🔐 OSINT API HUB</h1>
        <p>Powerful OSINT APIs | Blackhat Grade | No Limits</p>
        <a href="/endpoints" class="btn">📡 View Endpoints</a>
        <a href="/docs" class="btn">📚 API Docs</a>
        <a href="/login" class="btn">🔑 Admin Login</a>
        <p style="margin-top: 2rem;">Contact: @BMW_AURA4 | Channel: https://t.me/OSINTERA_1</p>
    </div>
</body>
</html>
