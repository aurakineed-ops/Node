<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSINT API Hub - Premium OSINT APIs</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            background: linear-gradient(135deg, #0a0a1a 0%, #0f0f2a 50%, #1a1a3a 100%);
            font-family: 'Inter', sans-serif;
            color: #e0e0e0;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }
        
        .bg-animation::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(0,255,200,0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        /* Glass Navbar */
        .navbar {
            background: rgba(10, 20, 30, 0.7);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0, 255, 200, 0.3);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .logo {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #00ffcc, #0099ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .nav-links a {
            color: #ccc;
            text-decoration: none;
            margin-left: 2rem;
            transition: 0.3s;
        }
        
        .nav-links a:hover { color: #00ffcc; text-shadow: 0 0 10px #00ffcc; }
        
        /* Hero Section */
        .hero {
            text-align: center;
            padding: 4rem 2rem;
        }
        
        .hero h1 {
            font-size: 4rem;
            font-weight: 800;
            background: linear-gradient(135deg, #fff, #00ffcc, #0099ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: glow 3s ease-in-out infinite;
        }
        
        @keyframes glow {
            0%, 100% { filter: brightness(1); }
            50% { filter: brightness(1.2); }
        }
        
        .hero p {
            font-size: 1.2rem;
            margin-top: 1rem;
            opacity: 0.8;
        }
        
        /* Stats Grid */
        .stats-grid {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin: 3rem auto;
            flex-wrap: wrap;
            max-width: 1000px;
        }
        
        .stat-card {
            background: rgba(0, 255, 200, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 255, 200, 0.2);
            border-radius: 20px;
            padding: 1.5rem 2rem;
            text-align: center;
            min-width: 150px;
            transition: 0.3s;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            border-color: #00ffcc;
            box-shadow: 0 0 30px rgba(0,255,200,0.2);
        }
        
        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            color: #00ffcc;
        }
        
        .stat-label {
            margin-top: 0.5rem;
            opacity: 0.7;
        }
        
        /* CTA Buttons */
        .cta-buttons {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin: 2rem 0;
            flex-wrap: wrap;
        }
        
        .btn {
            padding: 1rem 2rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
            display: inline-block;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #00ffcc, #0099ff);
            color: #000;
            border: none;
        }
        
        .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px #00ffcc;
        }
        
        .btn-outline {
            border: 2px solid #00ffcc;
            color: #00ffcc;
            background: transparent;
        }
        
        .btn-outline:hover {
            background: #00ffcc;
            color: #000;
            box-shadow: 0 0 20px #00ffcc;
        }
        
        /* Features Section */
        .features {
            max-width: 1200px;
            margin: 4rem auto;
            padding: 0 2rem;
        }
        
        .features h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 2rem;
            color: #00ffcc;
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }
        
        .feature-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(0, 255, 200, 0.1);
            border-radius: 20px;
            padding: 1.5rem;
            text-align: center;
            transition: 0.3s;
        }
        
        .feature-card:hover {
            border-color: #00ffcc;
            transform: translateY(-5px);
        }
        
        .feature-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        .feature-card h3 {
            margin-bottom: 0.5rem;
        }
        
        /* Footer */
        .footer {
            text-align: center;
            padding: 2rem;
            border-top: 1px solid rgba(0,255,200,0.2);
            margin-top: 4rem;
            background: rgba(0,0,0,0.3);
        }
        
        .footer a {
            color: #00ffcc;
            text-decoration: none;
        }
        
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .navbar { flex-direction: column; gap: 1rem; }
            .nav-links a { margin: 0 1rem; }
        }
    </style>
</head>
<body>
    <div class="bg-animation"></div>
    
    <nav class="navbar">
        <div class="logo">🔐 OSINT API HUB</div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/endpoints">📡 Endpoints</a>
            <a href="/docs">📚 Docs</a>
            <% if (user) { %>
                <a href="/admin/dashboard">⚙️ Dashboard</a>
                <a href="/logout">🚪 Logout</a>
            <% } else { %>
                <a href="/login">🔑 Admin</a>
            <% } %>
        </div>
    </nav>
    
    <div class="hero">
        <h1>🚀 Premium OSINT API Hub</h1>
        <p>18+ Powerful APIs | Blackhat Grade | 24/7 Uptime</p>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= totalApis %></div>
                <div class="stat-label">Available APIs</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= totalKeys %></div>
                <div class="stat-label">Active Keys</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= totalHits.toLocaleString() %></div>
                <div class="stat-label">Total API Hits</div>
            </div>
        </div>
        <div class="cta-buttons">
            <a href="/endpoints" class="btn btn-primary">📡 Explore APIs</a>
            <a href="/docs" class="btn btn-outline">📚 Read Docs</a>
            <a href="https://t.me/OSINTERA_1" class="btn btn-outline">💬 Join Channel</a>
        </div>
    </div>
    
    <div class="features">
        <h2>✨ Features</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🚀</div>
                <h3>18+ OSINT APIs</h3>
                <p>Telegram, Instagram, BGMI, Aadhar, PAN, Vehicle and more</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔐</div>
                <h3>API Key Management</h3>
                <p>Generate custom keys with expiry & API restrictions</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>Analytics Dashboard</h3>
                <p>Track usage, popular endpoints, and top users</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🧪</div>
                <h3>Test API Tool</h3>
                <p>Test any endpoint before integrating</p>
            </div>
        </div>
    </div>
    
    <div class="footer">
        <p>🔐 Need an API key? Contact <strong>@BMW_AURA4</strong> or <strong>@BMW_AURA1</strong></p>
        <p>📢 Join our channel: <a href="https://t.me/OSINTERA_1">https://t.me/OSINTERA_1</a></p>
        <p>© 2024 OSINT API Hub | All requests tracked for security</p>
    </div>
</body>
</html>
