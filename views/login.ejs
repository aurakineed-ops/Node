<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - OSINT API Hub</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0a0a2a, #1a1a3a);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: 'Segoe UI', 'Poppins', monospace;
        }

        .login-container {
            background: rgba(0, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 255, 255, 0.3);
            border-radius: 30px;
            padding: 2.5rem;
            width: 400px;
            box-shadow: 0 0 50px rgba(0, 255, 255, 0.1);
            transition: 0.3s;
        }

        .login-container:hover {
            box-shadow: 0 0 70px rgba(0, 255, 255, 0.2);
        }

        h2 {
            text-align: center;
            color: #00ffcc;
            margin-bottom: 1.5rem;
            font-size: 2rem;
            text-shadow: 0 0 10px #00ffcc;
        }

        .input-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            color: #00ffcc;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid rgba(0, 255, 255, 0.3);
            color: #00ffcc;
            border-radius: 12px;
            font-size: 1rem;
            transition: 0.3s;
        }

        input:focus {
            outline: none;
            border-color: #00ffcc;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);
        }

        input::placeholder {
            color: rgba(0, 255, 255, 0.4);
        }

        button {
            width: 100%;
            padding: 0.8rem;
            background: linear-gradient(135deg, #00ffcc22, #0099ff22);
            border: 1px solid #00ffcc;
            color: #00ffcc;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.3s;
        }

        button:hover {
            background: #00ffcc;
            color: #000;
            box-shadow: 0 0 20px #00ffcc;
        }

        .error-msg {
            background: rgba(255, 0, 0, 0.2);
            border: 1px solid #ff4444;
            border-radius: 10px;
            padding: 0.75rem;
            margin-bottom: 1rem;
            text-align: center;
            color: #ff8888;
            font-size: 0.9rem;
        }

        .footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.8rem;
            color: rgba(0, 255, 255, 0.5);
        }

        .footer a {
            color: #00ffcc;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <h2>🔐 Admin Login</h2>
        
        <% if (error) { %>
        <div class="error-msg">
            <% if (error === 'invalid') { %>❌ Invalid username or password
            <% } else if (error === 'missing') { %>❌ Please enter both username and password
            <% } else { %>❌ Login failed. Please try again
            <% } %>
        </div>
        <% } %>
        
        <form method="POST" action="/login">
            <div class="input-group">
                <label>📧 Username</label>
                <input type="text" name="username" placeholder="Enter your username" required autofocus>
            </div>
            <div class="input-group">
                <label>🔒 Password</label>
                <input type="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit">🚀 Login</button>
        </form>
        
        <div class="footer">
            <p>🔐 OSINT API Hub | <a href="/">Home</a></p>
        </div>
    </div>
</body>
</html>
