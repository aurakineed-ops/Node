<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - OSINT API Hub</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a0e27;
            color: #fff;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }
        
        .stat-number {
            font-size: 2em;
            font-weight: bold;
            color: #ffd700;
        }
        
        .card {
            background: #1a1f3a;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
        }
        
        .card h2 {
            margin-bottom: 20px;
            color: #ffd700;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #2a2f4a;
        }
        
        th {
            background: #667eea;
            color: #fff;
        }
        
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            margin: 2px;
        }
        
        .btn-danger {
            background: #e74c3c;
            color: white;
        }
        
        .btn-success {
            background: #2ecc71;
            color: white;
        }
        
        .btn-warning {
            background: #f39c12;
            color: white;
        }
        
        .btn-primary {
            background: #3498db;
            color: white;
        }
        
        input, select {
            padding: 8px;
            border-radius: 5px;
            border: 1px solid #2a2f4a;
            background: #0a0e27;
            color: #fff;
            margin: 5px;
        }
        
        .form-group {
            margin-bottom: 15px;
        }
        
        .form-group label {
            display: inline-block;
            width: 150px;
        }
        
        .badge {
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 12px;
        }
        
        .badge-success {
            background: #2ecc71;
        }
        
        .badge-danger {
            background: #e74c3c;
        }
        
        .badge-warning {
            background: #f39c12;
        }
        
        .nav-links {
            display: flex;
            gap: 15px;
        }
        
        .nav-links a {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            background: rgba(255,255,255,0.2);
            border-radius: 5px;
        }
        
        .logout {
            background: #e74c3c;
            color: white;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
        }
        
        .key-code {
            font-family: monospace;
            font-size: 12px;
            background: #0a0e27;
            padding: 3px 6px;
            border-radius: 3px;
        }
        
        @media (max-width: 768px) {
            table {
                font-size: 12px;
            }
            th, td {
                padding: 6px;
            }
            .form-group label {
                width: 100%;
                margin-bottom: 5px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔐 Admin Dashboard</h1>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/endpoints">Endpoints</a>
                <a href="/docs">Docs</a>
                <a href="/logout" class="logout">Logout</a>
            </div>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= totalHits %></div>
                <div>Total API Calls</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= active %></div>
                <div>Active Keys</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= keys.length %></div>
                <div>Total Keys</div>
            </div>
        </div>
        
        <!-- Generate Key Form -->
        <div class="card">
            <h2>🔑 Generate New API Key</h2>
            <form method="POST" action="/admin/generate-key">
                <div class="form-group">
                    <label>Key Name:</label>
                    <input type="text" name="name" placeholder="e.g., My API Key" required>
                </div>
                <div class="form-group">
                    <label>Owner Username:</label>
                    <input type="text" name="owner_username" placeholder="@username">
                </div>
                <div class="form-group">
                    <label>Owner Channel:</label>
                    <input type="text" name="owner_channel" placeholder="https://t.me/...">
                </div>
                <div class="form-group">
                    <label>Expiry:</label>
                    <select name="expiry">
                        <option value="">Never</option>
                        <option value="7d">7 Days</option>
                        <option value="15d">15 Days</option>
                        <option value="1m">1 Month</option>
                        <option value="1y">1 Year</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Unlimited Hits:</label>
                    <select name="unlimited">
                        <option value="false">No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Allowed APIs:</label>
                    <select name="allowed_apis">
                        <option value="all">All APIs</option>
                        <% apis.forEach(api => { %>
                            <option value="<%= api.name %>"><%= api.display_name %></option>
                        <% }) %>
                    </select>
                </div>
                
                <!-- Custom API Key Option -->
                <div class="form-group">
                    <label>
                        <input type="checkbox" id="enableCustomKey" name="enable_custom" value="true" onchange="toggleCustomKey()">
                        🔑 Create Custom API Key (any name you want)
                    </label>
                </div>
                
                <div id="customKeyDiv" style="display:none; margin-top: 10px; margin-bottom: 15px;">
                    <label>Custom API Key:</label>
                    <input type="text" name="custom_key" id="custom_key" placeholder="Enter your custom key (e.g., MY_SUPER_KEY, TEST123, etc.)" style="width: 300px;">
                    <small style="display: block; color: #888;">Minimum 5 characters, no spaces. Must be unique.</small>
                    <div id="keyStatus" style="margin-top: 5px;"></div>
                </div>
                
                <button type="submit" class="btn btn-success">Generate Key →</button>
            </form>
        </div>
        
        <!-- API Keys List -->
        <div class="card">
            <h2>📋 API Keys List</h2>
             <table>
                <thead>
                    <tr>
                        <th>API Key</th>
                        <th>Name</th>
                        <th>Owner</th>
                        <th>Hits</th>
                        <th>Today</th>
                        <th>Expiry</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% keys.forEach(key => { %>
                    <tr>
                        <td><code class="key-code"><%= key.key %></code></td>
                        <td><%= key.name %></td>
                        <td><%= key.owner_username || '-' %></td>
                        <td><%= key.hits || 0 %></td>
                        <td><span class="badge badge-success"><%= todayCalls[key.key] || 0 %></span></td>
                        <td><%= key.expires_at ? new Date(key.expires_at).toLocaleDateString() : 'Never' %></td>
                        <td>
                            <span class="badge <%= key.status === 'active' ? 'badge-success' : 'badge-danger' %>">
                                <%= key.status %>
                            </span>
                        </td>
                        <td>
                            <form method="POST" action="/admin/toggle-status" style="display:inline">
                                <input type="hidden" name="id" value="<%= key.id %>">
                                <input type="hidden" name="status" value="<%= key.status %>">
                                <button type="submit" class="btn btn-warning">
                                    <%= key.status === 'active' ? 'Disable' : 'Enable' %>
                                </button>
                            </form>
                            <form method="POST" action="/admin/delete-key" style="display:inline" onsubmit="return confirm('Delete this key?')">
                                <input type="hidden" name="id" value="<%= key.id %>">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <!-- Popular Endpoints -->
        <div class="card">
            <h2>🔥 Most Used Endpoints</h2>
            <table>
                <thead>
                    <tr>
                        <th>Endpoint</th>
                        <th>Calls</th>
                    </tr>
                </thead>
                <tbody>
                    <% popular.forEach(ep => { %>
                    <tr>
                        <td><%= ep.endpoint %></td>
                        <td><%= ep.count %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <!-- Top Users -->
        <div class="card">
            <h2>👥 Top API Key Users</h2>
            <table>
                <thead>
                    <tr>
                        <th>API Key</th>
                        <th>Calls</th>
                    </tr>
                </thead>
                <tbody>
                    <% topUsers.forEach(user => { %>
                    <tr>
                        <td><code class="key-code"><%= user.api_key %></code></td>
                        <td><%= user.calls %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    
    <script>
        function toggleCustomKey() {
            var checkbox = document.getElementById('enableCustomKey');
            var div = document.getElementById('customKeyDiv');
            div.style.display = checkbox.checked ? 'block' : 'none';
        }
        
        // Check key availability
        document.getElementById('custom_key')?.addEventListener('input', function() {
            var key = this.value;
            if(key.length >= 5) {
                fetch('/admin/check-key-availability', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({custom_key: key})
                })
                .then(res => res.json())
                .then(data => {
                    var statusDiv = document.getElementById('keyStatus');
                    if(data.available) {
                        statusDiv.innerHTML = '<span style="color: #2ecc71;">✅ ' + data.message + '</span>';
                    } else {
                        statusDiv.innerHTML = '<span style="color: #e74c3c;">❌ ' + data.message + '</span>';
                    }
                })
                .catch(err => {
                    console.error('Error checking key:', err);
                });
            } else {
                document.getElementById('keyStatus').innerHTML = '';
            }
        });
    </script>
</body>
</html>
