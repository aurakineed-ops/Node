<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>
    <style>
        body {
            background: linear-gradient(135deg, #0a0a2a, #1a1a3a);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: monospace;
        }
        .login-box {
            background: rgba(0,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid #0ff;
            border-radius: 20px;
            padding: 2rem;
            width: 350px;
        }
        input {
            width: 100%;
            padding: 0.75rem;
            margin: 0.5rem 0;
            background: #000;
            border: 1px solid #0ff;
            color: #0ff;
            border-radius: 10px;
        }
        button {
            width: 100%;
            padding: 0.75rem;
            background: #0ff;
            border: none;
            color: #000;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
        }
        h2 { text-align: center; color: #0ff; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>🔐 Admin Login</h2>
        <form method="POST">
            <input type="text" name="username" placeholder="Username" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit">Login</button>
        </form>
        <p style="text-align:center; margin-top:1rem;">Demo: superadmin / aura@1234</p>
    </div>
</body>
</html>